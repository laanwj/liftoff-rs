[Unit]
Description=Liftoff autonomous flight controller
After=network.target zenohd.service

[Service]
Type=simple
ExecStart=%h/.cargo/bin/liftoff-autopilot --mavlink $LIFTOFF_AUTOPILOT_ARGS
Environment=RUST_LOG=info
EnvironmentFile=-%h/.config/liftoff/env
Restart=on-failure
RestartSec=3

[Install]
WantedBy=liftoff.target
