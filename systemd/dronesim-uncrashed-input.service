[Unit]
Description=Uncrashed simulator bridge
After=network.target zenohd.service

[Service]
Type=simple
ExecStart=%h/.cargo/bin/uncrashed-input $DRONESIM_UNCRASHED_INPUT_ARGS
Environment=RUST_LOG=info
EnvironmentFile=-%h/.config/liftoff/env
Restart=on-failure
RestartSec=3

[Install]
WantedBy=dronesim.target
