[configuration]

entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.4
reloadable = true

[libraries]

linux.debug.x86_64   = "res://addons/godot-swarm-sim/libgodot_swarm_sim.so"
linux.release.x86_64 = "res://addons/godot-swarm-sim/libgodot_swarm_sim.so"
linux.debug.arm64    = "res://addons/godot-swarm-sim/libgodot_swarm_sim.so"
linux.release.arm64  = "res://addons/godot-swarm-sim/libgodot_swarm_sim.so"

macos.debug   = "res://addons/godot-swarm-sim/libgodot_swarm_sim.dylib"
macos.release = "res://addons/godot-swarm-sim/libgodot_swarm_sim.dylib"

windows.debug.x86_64   = "res://addons/godot-swarm-sim/godot_swarm_sim.dll"
windows.release.x86_64 = "res://addons/godot-swarm-sim/godot_swarm_sim.dll"
