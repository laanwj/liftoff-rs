; Engine configuration file for godot-swarm-sim
; Per the design plan in doc/godot-swarm-sim-plan.md:
;   - Godot 4.4+ (using 4.6.2 for development)
;   - Jolt as the rigid-body solver (default in 4.4+)
;   - 240 Hz physics tick

config_version=5

[application]

config/name="godot-swarm-sim"
config/description="Multi-drone FPV simulator"
run/main_scene="res://scenes/world.tscn"
config/features=PackedStringArray("4.4", "Mobile")

[debug]

settings/stdout/print_fps=false

[physics]

common/physics_ticks_per_second=240
common/max_physics_steps_per_frame=16
3d/physics_engine="JoltPhysics3D"

[rendering]

renderer/rendering_method="mobile"
